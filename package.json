{
  "name": "voicevibe",
  "version": "0.1.2",
  "description": "Open-source desktop voice typing inspired by Typeless.",
  "keywords": [
    "electron",
    "voice-input",
    "speech-to-text",
    "dictation",
    "asr",
    "whisper",
    "vibevoice"
  ],
  "license": "MIT",
  "author": {
    "name": "VoiceVibe"
  },
  "homepage": "https://github.com/yeyitech/voicevibe",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeyitech/voicevibe.git"
  },
  "bugs": {
    "url": "https://github.com/yeyitech/voicevibe/issues"
  },
  "main": "./dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg zip --x64 --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.3.1",
    "electron-builder": "^26.6.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.3"
  },
  "optionalDependencies": {
    "iohook-macos": "1.2.1"
  }
}
